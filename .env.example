# REX-OS Environment Configuration Example
# Copy this file to .env and update values as needed

# === Core Configuration ===
FLASK_ENV=development
FLASK_DEBUG=True
API_HOST=0.0.0.0
API_PORT=5000
SECRET_KEY=your-secret-key-here

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/rex-os.log

# === Agent Configuration ===
CORE_URL=http://localhost:5000
AGENT_NAME=node-01
AGENT_ID=agent-001
COLLECTION_INTERVAL=5

# === Database (if used) ===
DATABASE_URL=sqlite:///rex-os.db

# === Security ===
ENABLE_AUTH=False
API_KEY=

# === Development ===
DEBUG=True
TESTING=False
